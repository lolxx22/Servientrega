# ===========================================
# SERVIBOT AI - Variables de Entorno (Ejemplo)
# ===========================================
# Copia este archivo como .env y reemplaza los valores

# ===========================================
# BASE DE DATOS (PostgreSQL via Docker)
# ===========================================
# Formato: postgresql://usuario:password@host:puerto/nombre_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/servibot

# ===========================================
# SEGURIDAD
# ===========================================
# JWT_SECRET: Clave secreta para firmar tokens (minimo 10 caracteres)
# IMPORTANTE: Usa una clave fuerte en produccion
JWT_SECRET=servibot-jwt-secret-2026-secure-key

# ===========================================
# API EXTERNA
# ===========================================
# OPENROUTER_API_KEY: API key de OpenRouter para el chatbot AI
# Obtener en: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ===========================================
# SERVIDOR
# ===========================================
# PORT: Puerto del backend (default: 3000)
PORT=3000

# NODE_ENV: entorno de ejecucion (development | production | test)
NODE_ENV=development

# ===========================================
# FRONTEND
# ===========================================
# APP_URL: URL del frontend para CORS
APP_URL=http://localhost:5173

# APP_NAME: Nombre de la aplicacion
APP_NAME=Servibot AI

# VITE_API_URL: URL del API para el frontend (Vite)
VITE_API_URL=http://localhost:3000/api
